# ─────────────────────────────────────────────────────────────────────────────
# Root .env — Docker Compose reads this file automatically.
# Copy to .env and fill in the values. NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Laravel application key (generate with: php artisan key:generate --show)
APP_KEY=

# MySQL
DB_PASSWORD=change_me_in_production
MYSQL_ROOT_PASSWORD=change_root_password

# Passport OAuth2 Password Grant client
# Create with the PHP snippet in README.md after first `docker compose up`
PASSPORT_CLIENT_ID=
PASSPORT_CLIENT_SECRET=

# Next.js
NEXTAUTH_SECRET=change_this_to_a_random_64_char_string

# Redis password (optional but recommended in production)
REDIS_PASSWORD=
