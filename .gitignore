# ══════════════════════════════════════════════════════════════════════════════
# .gitignore — Ecommerce Boilerplate
# ══════════════════════════════════════════════════════════════════════════════

# ── Secrets & credentials ─────────────────────────────────────────────────────
# Root .env (Docker Compose reads this — contains APP_KEY, DB_PASSWORD, etc.)
.env
# Laravel application .env
backend/.env
backend/.env.*
!backend/.env.example
# Next.js local env overrides
.env.local
.env.*.local
# Passport RSA private key — if leaked, anyone can forge JWT tokens
backend/storage/oauth-private.key

# ── PHP / Laravel ─────────────────────────────────────────────────────────────
backend/vendor/
backend/bootstrap/cache/*.php
# Laravel runtime directories (recreated on boot)
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
# Logs — may contain stack traces, SQL queries, user data
backend/storage/logs/*
# Keep the directory structure (gitkeep files ARE committed)
!backend/storage/logs/.gitkeep
!backend/storage/framework/cache/data/.gitkeep
!backend/storage/framework/sessions/.gitkeep
!backend/storage/framework/views/.gitkeep
# Laravel test database
backend/database/database.sqlite

# ── Next.js / Node ────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
# next-env.d.ts is auto-generated by Next.js — should not be manually edited
# but it IS committed as per Next.js docs recommendation
# frontend/next-env.d.ts  ← keep this commented (should be committed)

# ── Docker volumes ────────────────────────────────────────────────────────────
mysql_data/
redis_data/

# ── OS & editors ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Testing ───────────────────────────────────────────────────────────────────
backend/.phpunit.result.cache
backend/coverage/
frontend/coverage/
